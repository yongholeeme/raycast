{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "vscode-helper",
  "title": "Vscode Helper",
  "description": "It helps to open visual studio easily",
  "icon": "vscode-helper-icon.png",
  "author": "yongholee",
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "Open VSC",
      "description": "It helps to open visual studio easily",
      "mode": "view",
      "preferences": [
        {
          "title": "Root Directory",
          "name": "ROOT_DIRECTORY",
          "description": "Directory where vscodes are clustered",
          "type": "directory",
          "required": true
        }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.45.2"
  },
  "devDependencies": {
    "@types/node": "18.8.3",
    "@types/react": "18.0.9",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "prettier": "^2.5.1",
    "typescript": "^4.4.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "ray publish"
  }
}
